<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="将此公钥添加到 GitHub/GitLab 的 SSH Keys 设置中"
        android:textColor="@color/ios_secondary_label"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/txt_public_key"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ios_tertiary_background"
        android:fontFamily="monospace"
        android:padding="12dp"
        android:textColor="@color/ios_label"
        android:textSize="12sp"
        android:textIsSelectable="true" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_copy_key"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="复制公钥"
        style="@style/iOSButton" />

</LinearLayout>